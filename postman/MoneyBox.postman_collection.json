                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "me"]
                }
              }
            }
          ]
        },
        {
          "name": "SCENARIO B: Logout isolation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('=== SCENARIO B: Logout isolation ===');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "item": [
            {
              "name": "1. Tab A Logout",
              "request": {
                "method": "POST",
                "header": [{ "key": "X-Tab-Id", "value": "{{tab_a_id}}" }],
                "url": {
                  "raw": "{{base_url}}/api/auth/logout",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "logout"]
                }
              }
            },
            {
              "name": "2. Tab A Now Unauthenticated",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Tab A logged out\", function () {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json.authenticated).to.be.false;",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "X-Tab-Id", "value": "{{tab_a_id}}" }],
                "url": {
                  "raw": "{{base_url}}/api/auth/me",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "me"]
                }
              }
            },
            {
              "name": "3. Tab B Still Authenticated (Isolation Verified)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Tab B session intact after Tab A logout\", function () {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json.authenticated).to.be.true;",
                      "    pm.expect(json.user.email).to.eql(pm.variables.get('user_email'));",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "X-Tab-Id", "value": "{{tab_b_id}}" }],
                "url": {
                  "raw": "{{base_url}}/api/auth/me",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "me"]
                }
              }
            },
            {
              "name": "4. Tab A Can Login as Different User",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-Tab-Id", "value": "{{tab_a_id}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"email\": \"{{user_b_email}}\", \"password\": \"{{user_b_password}}\"}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "login"]
                }
              }
            },
            {
              "name": "5. Tab A Now Shows New User (Tab B Unchanged)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Tab A now logged in as different user\", function () {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json.authenticated).to.be.true;",
                      "    pm.expect(json.user.email).to.eql(pm.variables.get('user_b_email'));",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [{ "key": "X-Tab-Id", "value": "{{tab_a_id}}" }],
                "url": {
                  "raw": "{{base_url}}/api/auth/me",
                  "host": ["{{base_url}}"],
                  "path": ["api", "auth", "me"]
                }
              }
            }
          ]
        }
      ]
    }
  ]
