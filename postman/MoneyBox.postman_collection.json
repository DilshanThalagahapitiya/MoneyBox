                  "pm.test(\"Session cleared for this tab\", function () {",
                  "    pm.sendRequest({",
                  "        url: pm.variables.get('base_url') + '/api/auth/me',",
                  "        method: 'GET',",
                  "        header: { 'X-Tab-Id': pm.variables.get('tab_a_id') }",
